# ─── Kong Admin API Integration ───────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real credentials.

# Set to "true" to enable live Kong API calls. "false" uses mock data.
VITE_KONG_ENABLED=false

# URL path prefix for Kong API calls from the browser.
# In dev: Vite proxies /kong-api → VITE_KONG_ADMIN_URL (set below).
# In production (Netlify): set to /.netlify/functions/kong-proxy
VITE_KONG_API_URL=/kong-api

# Your Kong Admin API base URL (used by the Vite dev proxy and Netlify function).
# Example: http://localhost:8001  or  https://kong-admin.yourcompany.com:8001
VITE_KONG_ADMIN_URL=http://localhost:8001

# Kong Admin API key (if your Admin API is secured with key-auth).
# Leave blank if your Admin API has no authentication (common in local dev).
VITE_KONG_API_KEY=
